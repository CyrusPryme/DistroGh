    "clsx": "^2.1.0",
    "date-fns": "^3.3.1",
    "dotenv": "^16.6.1",
    "exceljs": "^4.4.0",
    "jose": "^6.1.0",
    "lucide-react": "^0.323.0",
    "next": "^16.1.6",
    "pg": "^8.16.0",
    "react": "^18",
    "react-dom": "^18",
    "react-dropzone": "^14.2.3",
    "react-hook-form": "^7.50.1",
    "recharts": "^2.12.0",
    "tailwind-merge": "^2.2.1",
    "tailwindcss-animate": "^1.0.7",
