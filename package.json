{
  "name": "consignment-distribution-system",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "db:migrate": "node -r dotenv/config scripts/db-migrate.mjs dotenv_config_path=.env.local",
    "db:seed": "node -r dotenv/config scripts/db-seed.mjs dotenv_config_path=.env.local",
    "db:setup": "npm run db:up && npm run db:migrate && npm run db:seed",
    "generate:sample-sales": "node scripts/generate-sample-sales.mjs",
    "generate:static-sample": "node scripts/generate-static-sample.mjs",
    "start": "next start",
    "lint": "next lint",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.3.4",
    "@radix-ui/react-avatar": "^1.0.4",
    "@radix-ui/react-dialog": "^1.0.5",
    "@radix-ui/react-dropdown-menu": "^2.0.6",
    "@radix-ui/react-label": "^2.0.2",
    "@radix-ui/react-progress": "^1.0.3",
    "@radix-ui/react-select": "^2.0.0",
    "@radix-ui/react-separator": "^1.0.3",
    "@radix-ui/react-slot": "^1.0.2",
    "@radix-ui/react-switch": "^1.0.3",
    "@radix-ui/react-tabs": "^1.0.4",
    "@radix-ui/react-toast": "^1.1.5",
    "@radix-ui/react-tooltip": "^1.0.7",
    "bcryptjs": "^3.0.2",
