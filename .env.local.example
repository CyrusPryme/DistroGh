# Local Postgres (Docker)
# Start with: npm run db:up && npm run db:migrate && npm run db:seed
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/consignment

# Auth (change in production)
AUTH_SECRET=change-me-to-a-long-random-string

# App Configuration
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME="DistroGH - Consignment Management"

# FDA certificates (Google Drive — required for uploads on Vercel/production)
# 1. Create a Google Cloud service account with Drive API enabled
# 2. Share your FDA folder with the service account email (Editor)
# 3. Paste the full JSON key as a single line (or use Vercel env var)
GOOGLE_SERVICE_ACCOUNT_JSON=
GOOGLE_DRIVE_FDA_FOLDER_ID=
